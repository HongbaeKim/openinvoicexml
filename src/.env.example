# DATABASE_URL and POSTGRES_PASSWORD must be changed together (see docker-compose.yml comments)
# — DATABASE_URL is what the backend connects with, POSTGRES_PASSWORD is what the Postgres
# server is initialized with. Changing only one breaks auth.
DATABASE_URL=postgres://app:app@postgres:5432/app
POSTGRES_PASSWORD=app
# Port the server listens on inside the container (or directly, for non-Docker `npm run dev`).
PORT=3000
# Host-side port docker-compose publishes PORT to. Change this if 3000 is already taken on
# your machine — the container's internal port (PORT, above) stays 3000 either way.
HOST_PORT=3000
# Host interface docker-compose binds published ports to. Default (127.0.0.1) is loopback-only
# — nothing outside this machine can reach it. Set to 0.0.0.0 to reach it from another device on
# your LAN (e.g. browsing from your own machine while the stack runs on a remote dev box). Leave
# at the default on the VPS — nginx should be the only thing publicly reachable there.
BIND_HOST=127.0.0.1
# Must match whatever origin the browser actually sends. If you set BIND_HOST=0.0.0.0 to access
# the frontend via a LAN IP (e.g. http://x.x.x.x:8080), update this to match
# (http://x.x.x.x:8080) or CORS will reject the request.
ALLOWED_ORIGIN=http://localhost:8080
