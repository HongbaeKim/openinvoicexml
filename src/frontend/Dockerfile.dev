# Dev-only: runs Vite's dev server for local `docker compose up` convenience. The frontend's
# actual production artifact is a static `npm run build` output deployed via GitHub Pages — this
# file is never used for that.
FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
EXPOSE 8080
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
